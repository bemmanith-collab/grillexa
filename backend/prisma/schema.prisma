generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// Postgres in all environments (production on Fly.io, local dev via
// docker-compose or any reachable Postgres instance). DATABASE_URL is
// supplied via environment variable / Fly secret, never hardcoded.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// role/type fields are plain Strings rather than Prisma enums so this
// schema stays portable; values are validated in application code.

// role: "ADMIN" | "MANAGER" | "SALES"
// SALES accounts must be assigned at least one store (enforced in the users
// route, not in the schema, so ADMIN/MANAGER can stay company-wide). Stores
// and SALES users are many-to-many — a store can have more than one sales
// person assigned (e.g. a backup covering for someone who's out) and a
// sales person can cover several stores.
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  passwordHash String
  role      String   @default("SALES")
  createdAt DateTime @default(now())

  stores           Store[]
  dispatchInvoices DispatchInvoice[]
  sales            Sale[]
  returns          Return[]
  consignments     Consignment[]
  settlements      Settlement[]
}

model Store {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now())

  salesUsers        User[]
  dailyStockEntries DailyStockEntry[]
  dispatchInvoices  DispatchInvoice[]
  sales             Sale[]
  returns           Return[]
  consignments      Consignment[]
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  sku       String   @unique
  price     Float    @default(0)
  // What it costs to stock this product — distinct from the selling price
  // above. Drives the Profit & Loss report (profit = price - costPrice).
  costPrice Float    @default(0)
  // Company-wide default reorder point; used to flag a store's closing stock as low.
  threshold Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyStockEntries    DailyStockEntry[]
  dispatchInvoiceLines DispatchInvoiceLine[]
  saleLines            SaleLine[]
  returns              Return[]
  consignmentItems     ConsignmentItem[]
}

// One row per (date, store, product) — the daily stock ledger.
// closing = opening + received - sold - wastage, recomputed whenever
// a dispatch, sale, or wastage entry touches this date/store/product.
// consignmentQty is a separate running balance (like closing, not a daily
// delta like received/sold/wastage) tracking how much of the physical
// stock at this store is still on consignment — delivered but not yet
// settled. See backend/src/lib/stock.js for how it's carried forward.
model DailyStockEntry {
  id             Int      @id @default(autoincrement())
  date           DateTime
  storeId        Int
  store          Store    @relation(fields: [storeId], references: [id])
  productId      Int
  product        Product  @relation(fields: [productId], references: [id])
  opening        Int      @default(0)
  received       Int      @default(0)
  sold           Int      @default(0)
  wastage        Int      @default(0)
  closing        Int      @default(0)
  consignmentQty Int      @default(0)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([date, storeId, productId], name: "dailyEntryKey")
}

// The "bill" for stock sent from HQ to a store.
model DispatchInvoice {
  id          Int      @id @default(autoincrement())
  number      String   @unique
  date        DateTime
  storeId     Int
  store       Store    @relation(fields: [storeId], references: [id])
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  totalAmount Float
  createdAt   DateTime @default(now())

  lines DispatchInvoiceLine[]
}

model DispatchInvoiceLine {
  id        Int             @id @default(autoincrement())
  invoiceId Int
  invoice   DispatchInvoice @relation(fields: [invoiceId], references: [id])
  productId Int
  product   Product         @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  amount    Float
}

// A retail sales bill issued by a store to a customer. Customer fields are
// all optional walk-in retail sales usually have none of these — they only
// get filled in when the bill needs to double as a proper invoice (e.g. the
// customer wants their GSTIN on it for input tax credit).
model Sale {
  id            Int          @id @default(autoincrement())
  number        String       @unique
  date          DateTime
  storeId       Int
  store         Store        @relation(fields: [storeId], references: [id])
  createdById   Int
  createdBy     User         @relation(fields: [createdById], references: [id])
  totalAmount   Float
  customerName  String?
  customerPhone String?
  customerGstin String?
  createdAt     DateTime     @default(now())
  // Set only for sales generated by settling a Consignment (see
  // Settlement below) — null for legacy sales entered before the
  // consignment model existed, or any hand-entered sale.
  consignmentId Int?
  consignment   Consignment? @relation(fields: [consignmentId], references: [id])

  lines      SaleLine[]
  settlement Settlement?
}

// type: "SALE" | "RETURN". A RETURN line credits its quantity back to stock
// instead of deducting it, and its amount is subtracted from the sale's
// totalAmount instead of added — this is what lets one bill cover both a
// sale and a same-visit return/exchange. reason mirrors Return.reason and
// is only set when type = "RETURN".
model SaleLine {
  id        Int     @id @default(autoincrement())
  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  amount    Float
  type      String  @default("SALE")
  reason    String?
}

// reason: "CUSTOMER_RETURN" | "DAMAGED" | "EXCHANGE" | "OTHER" | "CONSIGNMENT_UNSOLD"
// An audit ledger row, written automatically whenever a Sale is created with
// a RETURN-type line (see SaleLine.type) — one row per returned product.
// Also written directly (reason "CONSIGNMENT_UNSOLD") when a Consignment is
// settled with unsold stock — see the /consignments/:id/settle route, which
// writes these without going through POST /returns (that endpoint's
// processReturn() credits stock back into the store, which is the wrong
// direction for stock leaving the store back to HQ).
model Return {
  id          Int      @id @default(autoincrement())
  date        DateTime
  storeId     Int
  store       Store    @relation(fields: [storeId], references: [id])
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  reason      String
  reference   String?
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

// The sale-or-return model this business runs on: HQ delivers stock to a
// store (this record, status DELIVERED) but doesn't recognize revenue or
// charge GST until the store reports what actually sold — see Settlement.
// status: "DELIVERED" | "PARTIAL_SETTLED" | "SETTLED" | "RETURNED"
// (RETURNED is a fully-settled consignment where nothing sold at all.)
model Consignment {
  id            Int      @id @default(autoincrement())
  consignmentNo String   @unique
  storeId       Int
  store         Store    @relation(fields: [storeId], references: [id])
  createdById   Int
  createdBy     User     @relation(fields: [createdById], references: [id])
  status        String   @default("DELIVERED")
  deliveredAt   DateTime
  settledAt     DateTime?
  notes         String?
  createdAt     DateTime @default(now())

  items       ConsignmentItem[]
  settlements Settlement[]
  sales       Sale[]
}

// soldQty/returnedQty are cumulative totals across every Settlement made
// against this consignment (a consignment can be settled in more than one
// pass — see SettlementLine for the per-event breakdown). Never exceeds
// deliveredQty; enforced in the /consignments/:id/settle route.
model ConsignmentItem {
  id            Int         @id @default(autoincrement())
  consignmentId Int
  consignment   Consignment @relation(fields: [consignmentId], references: [id])
  productId     Int
  product       Product     @relation(fields: [productId], references: [id])
  deliveredQty  Int
  soldQty       Int         @default(0)
  returnedQty   Int         @default(0)
  pricePerUnit  Float
  // deliveredQty * pricePerUnit — the consignment's face value, not revenue.
  // Revenue is only recognized on the Sale a Settlement generates.
  totalValue    Float

  settlementLines SettlementLine[]
}

// One row per settlement action/visit — a Consignment can be settled in
// multiple passes over multiple days, so this is the audit trail of each
// one, not a mutable summary. saleId is set only if this settlement had
// any sold quantity (it generates exactly one Sale covering everything
// sold in this pass); a settlement that was 100% unsold has no Sale.
model Settlement {
  id            Int         @id @default(autoincrement())
  settlementNo  String      @unique
  consignmentId Int
  consignment   Consignment @relation(fields: [consignmentId], references: [id])
  createdById   Int
  createdBy     User        @relation(fields: [createdById], references: [id])
  settledAt     DateTime
  notes         String?
  saleId        Int?        @unique
  sale          Sale?       @relation(fields: [saleId], references: [id])
  createdAt     DateTime    @default(now())

  lines SettlementLine[]
}

// soldQty/returnedQty here are what was settled in THIS pass only (not
// cumulative — see ConsignmentItem for the running totals).
model SettlementLine {
  id                Int             @id @default(autoincrement())
  settlementId      Int
  settlement        Settlement      @relation(fields: [settlementId], references: [id])
  consignmentItemId Int
  consignmentItem   ConsignmentItem @relation(fields: [consignmentItemId], references: [id])
  soldQty           Int             @default(0)
  returnedQty       Int             @default(0)
}
