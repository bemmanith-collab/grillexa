generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// Postgres in all environments (production on Fly.io, local dev via
// docker-compose or any reachable Postgres instance). DATABASE_URL is
// supplied via environment variable / Fly secret, never hardcoded.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// role/type fields are plain Strings rather than Prisma enums so this
// schema stays portable; values are validated in application code.

// role: "ADMIN" | "MANAGER" | "SALES"
// SALES accounts must be assigned at least one store (enforced in the users
// route, not in the schema, so ADMIN/MANAGER can stay company-wide). Stores
// and SALES users are many-to-many — a store can have more than one sales
// person assigned (e.g. a backup covering for someone who's out) and a
// sales person can cover several stores.
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  passwordHash String
  role      String   @default("SALES")
  createdAt DateTime @default(now())

  stores           Store[]
  dispatchInvoices DispatchInvoice[]
  sales            Sale[]
  returns          Return[]
}

model Store {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now())

  salesUsers        User[]
  dailyStockEntries DailyStockEntry[]
  dispatchInvoices  DispatchInvoice[]
  sales             Sale[]
  returns           Return[]
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  sku       String   @unique
  price     Float    @default(0)
  // What it costs to stock this product — distinct from the selling price
  // above. Drives the Profit & Loss report (profit = price - costPrice).
  costPrice Float    @default(0)
  // Company-wide default reorder point; used to flag a store's closing stock as low.
  threshold Int      @default(10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dailyStockEntries    DailyStockEntry[]
  dispatchInvoiceLines DispatchInvoiceLine[]
  saleLines            SaleLine[]
  returns              Return[]
}

// One row per (date, store, product) — the daily stock ledger.
// closing = opening + received - sold - wastage, recomputed whenever
// a dispatch, sale, or wastage entry touches this date/store/product.
model DailyStockEntry {
  id        Int      @id @default(autoincrement())
  date      DateTime
  storeId   Int
  store     Store    @relation(fields: [storeId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  opening   Int      @default(0)
  received  Int      @default(0)
  sold      Int      @default(0)
  wastage   Int      @default(0)
  closing   Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([date, storeId, productId], name: "dailyEntryKey")
}

// The "bill" for stock sent from HQ to a store.
model DispatchInvoice {
  id          Int      @id @default(autoincrement())
  number      String   @unique
  date        DateTime
  storeId     Int
  store       Store    @relation(fields: [storeId], references: [id])
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  totalAmount Float
  createdAt   DateTime @default(now())

  lines DispatchInvoiceLine[]
}

model DispatchInvoiceLine {
  id        Int             @id @default(autoincrement())
  invoiceId Int
  invoice   DispatchInvoice @relation(fields: [invoiceId], references: [id])
  productId Int
  product   Product         @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  amount    Float
}

// A retail sales bill issued by a store to a customer. Customer fields are
// all optional walk-in retail sales usually have none of these — they only
// get filled in when the bill needs to double as a proper invoice (e.g. the
// customer wants their GSTIN on it for input tax credit).
model Sale {
  id            Int      @id @default(autoincrement())
  number        String   @unique
  date          DateTime
  storeId       Int
  store         Store    @relation(fields: [storeId], references: [id])
  createdById   Int
  createdBy     User     @relation(fields: [createdById], references: [id])
  totalAmount   Float
  customerName  String?
  customerPhone String?
  customerGstin String?
  createdAt     DateTime @default(now())

  lines SaleLine[]
}

// type: "SALE" | "RETURN". A RETURN line credits its quantity back to stock
// instead of deducting it, and its amount is subtracted from the sale's
// totalAmount instead of added — this is what lets one bill cover both a
// sale and a same-visit return/exchange. reason mirrors Return.reason and
// is only set when type = "RETURN".
model SaleLine {
  id        Int     @id @default(autoincrement())
  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  amount    Float
  type      String  @default("SALE")
  reason    String?
}

// reason: "CUSTOMER_RETURN" | "DAMAGED" | "EXCHANGE" | "OTHER"
// An audit ledger row, written automatically whenever a Sale is created with
// a RETURN-type line (see SaleLine.type) — one row per returned product.
model Return {
  id          Int      @id @default(autoincrement())
  date        DateTime
  storeId     Int
  store       Store    @relation(fields: [storeId], references: [id])
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int
  reason      String
  reference   String?
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}
